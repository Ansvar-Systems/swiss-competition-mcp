{
  "name": "@ansvar/swiss-competition-mcp",
  "version": "0.1.0",
  "mcpName": "eu.ansvar/swiss-competition-mcp",
  "description": "COMCO (Swiss Competition Commission) MCP server — competition law decisions, merger control, and sector enforcement under Swiss competition law (KG/LCart)",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": { "swiss-competition-mcp": "dist/src/index.js" },
  "files": ["dist", "server.json"],
  "engines": { "node": ">=20" },
  "repository": { "type": "git", "url": "git+https://github.com/Ansvar-Systems/swiss-competition-mcp.git" },
  "bugs": { "url": "https://github.com/Ansvar-Systems/swiss-competition-mcp/issues" },
  "homepage": "https://github.com/Ansvar-Systems/swiss-competition-mcp#readme",
  "keywords": ["mcp", "model-context-protocol", "ai", "claude", "comco", "swiss-competition", "switzerland", "antitrust", "merger-control", "compliance", "ansvar"],
  "author": "Ansvar Systems AB <hello@ansvar.ai>",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/http-server.ts",
    "start": "node dist/src/http-server.js",
    "seed": "npx tsx scripts/seed-sample.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^9.4.3",
